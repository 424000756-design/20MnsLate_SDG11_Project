<?xml version="1.0" encoding="utf-8"?>
<configuration>
    <configSections>
    </configSections>
    <connectionStrings>
        <add name="AIO.My.MySettings.BuildingInspection_DBConnectionString"
            connectionString="Data Source=.\SQLEXPRESS;Initial Catalog=BuildingInspection_DB;Integrated Security=True;TrustServerCertificate=True"
            providerName="System.Data.SqlClient" />
        <add name="AIO.My.MySettings.BuildingSafety_DBConnectionString"
